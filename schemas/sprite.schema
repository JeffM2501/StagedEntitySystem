namespace Sprite


struct GridFrameInfo
{
    float Width = 0;
    float Height = 0;
}

enum FrameTypeEnum
{
    Grid,
    List,
}

struct FrameTypeInfo
{
    FrameTypeEnum Type;

    <dependent Type = Grid>
    GridFrameInfo GridInfo;

    <dependent Type = List>
    Rectangle[] Frames;
}

asset Sprite
{
    AssetReference Image;
    FrameTypeEnum FrameType;
}