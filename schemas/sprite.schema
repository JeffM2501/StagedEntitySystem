namespace Sprite


struct GridFrameInfo
{
    float Width = 0;
    float Height = 0;
}

struct FrameRectangle
{
    float X = 0;
    float Y = 0;
    float EWidth = 0;
    float Height = 0;
}

enum FrameTypeEnum
{
    Grid,
    List,
}

struct FrameTypeInfo
{
    FrameTypeEnum Type;

    <dependent Type = Grid>
    GridFrameInfo GridInfo;

    <dependent Type = List>
    FrameRectangle[] Frames;
}

asset Sprite
{
    AssetReference Image;
    FrameTypeEnum FrameType;
}